{
  "model": "HuggingFaceTB/SmolLM2-135M-Instruct",
  "mode": "full",
  "device": "auto",
  "dtype": "bfloat16",
  "resumed_from": null,
  "n_train": 3000,
  "lora": {
    "r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05
  },
  "grpo": {
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "num_generations": 8,
    "max_completion_length": 80,
    "learning_rate": 5e-05,
    "beta": 0.05,
    "bf16": true,
    "gradient_checkpointing": true,
    "logging_steps": 10,
    "save_steps": 100,
    "max_steps": 300
  }
}